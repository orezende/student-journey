{
  "name": "student-journey",
  "version": "1.0.0",
  "license": "MIT",
  "workspaces": [
    "lib/*"
  ],
  "scripts": {
    "dev": "nodemon",
    "build": "npm run lint && tsc",
    "start": "node --env-file=.env dist/src/server.js",
    "lint": "prettier --check src && eslint src --max-warnings 0",
    "lint-fix": "prettier --write src && eslint src --fix",
    "quality:setup": "tsx lib/quality/setup.ts",
    "migration:generate": "f() { tsx lib/db/cli/generate.ts src/db/migrations/$1; }; f",
    "migration:run": "tsx lib/db/cli/run.ts",
    "migration:revert": "tsx lib/db/cli/revert.ts",
    "unit": "tsx lib/testing/cli/run.ts unit",
    "integration": "tsx lib/testing/cli/run.ts integration",
    "test": "tsx lib/testing/cli/run.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
